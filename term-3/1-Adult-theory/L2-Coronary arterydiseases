<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Heart & CAD | القلب والشريان التاجي</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300&family=Amiri:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
<style>
:root{
  --ink:#0d1117;--ink-soft:#3a3f47;--ink-muted:#7a808a;
  --cream:#f3f6ff;--paper:#ffffff;
  --blue:#1a3a8c;--blue-light:#dde9f8;
  --teal:#0e5a6a;--teal-light:#cffafe;
  --gold:#c9a84c;--gold-light:#f0dea0;
  --green:#1a6b4a;--green-light:#d4ede2;
  --red:#c0392b;--red-light:#fce8e6;
  --purple:#7c3aed;--purple-light:#ede9fe;
  --orange:#b45309;--orange-light:#fef3c7;
  --border:#e2ddd5;--shadow:0 2px 20px rgba(0,0,0,.07);
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'DM Sans',sans-serif;background:var(--cream);color:var(--ink);min-height:100vh;overflow-x:hidden;}
body::before{content:'';position:fixed;inset:0;background:radial-gradient(ellipse 80% 50% at 10% 20%,rgba(192,57,43,.05) 0%,transparent 60%),radial-gradient(ellipse 60% 70% at 90% 80%,rgba(26,58,140,.04) 0%,transparent 60%);pointer-events:none;z-index:0;}

#splash{position:fixed;inset:0;z-index:100;background:var(--ink);display:flex;flex-direction:column;align-items:center;justify-content:flex-start;gap:13px;transition:opacity .6s,transform .6s;padding:22px 22px 36px;overflow-y:auto;}
#splash.hidden{opacity:0;pointer-events:none;transform:scale(1.03);}
.splash-badge{width:68px;height:68px;border:2px solid #8b1a1a;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:28px;animation:pulse-ring 2s ease infinite;flex-shrink:0;}
@keyframes pulse-ring{0%,100%{box-shadow:0 0 0 0 rgba(139,26,26,.4);}50%{box-shadow:0 0 0 12px rgba(139,26,26,0);}}
.splash-title{font-family:'DM Serif Display',serif;font-size:clamp(20px,5vw,32px);color:#fff;text-align:center;line-height:1.2;}
.splash-title span{color:#e87070;}
.splash-subtitle{font-family:'Amiri',serif;font-size:17px;color:rgba(255,255,255,.6);direction:rtl;text-align:center;}
.splash-prof{font-size:11px;color:rgba(255,255,255,.3);letter-spacing:.06em;text-align:center;}
.splash-pills{display:flex;gap:8px;flex-wrap:wrap;justify-content:center;}
.s-pill{padding:6px 14px;border-radius:30px;font-size:11px;font-weight:600;}
.s-pill.a{background:rgba(139,26,26,.3);color:#f1948a;border:1px solid rgba(139,26,26,.5);}
.s-pill.b{background:rgba(26,58,140,.3);color:#93b4ff;border:1px solid rgba(26,58,140,.5);}
.s-pill.c{background:rgba(201,168,76,.3);color:#f0dea0;border:1px solid rgba(201,168,76,.5);}
.s-pill.d{background:rgba(26,107,74,.3);color:#6ee7b7;border:1px solid rgba(26,107,74,.5);}
.splash-meta{display:flex;gap:20px;flex-wrap:wrap;justify-content:center;}
.splash-stat{text-align:center;color:rgba(255,255,255,.7);}
.splash-stat strong{display:block;font-size:26px;font-weight:600;color:#e87070;}
.splash-stat span{font-size:11px;letter-spacing:.05em;}
.splash-divider{width:100%;max-width:380px;height:1px;background:rgba(255,255,255,.08);}
.splash-section-label{font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:rgba(255,255,255,.3);}
.review-mode-btn{padding:10px 28px;border-radius:8px;border:1.5px solid #e87070;background:transparent;color:#e87070;font-size:14px;font-weight:600;font-family:'DM Sans',sans-serif;cursor:pointer;transition:all .2s;}
.review-mode-btn:hover{background:rgba(232,112,112,.1);}
.section-filter{display:flex;gap:8px;flex-wrap:wrap;justify-content:center;}
.filter-btn{padding:6px 13px;border-radius:20px;border:1.5px solid rgba(255,255,255,.2);background:transparent;color:rgba(255,255,255,.7);font-size:11px;font-weight:600;font-family:'DM Sans',sans-serif;cursor:pointer;transition:all .2s;}
.filter-btn:hover,.filter-btn.active{border-color:#e87070;color:#e87070;}
.filter-btn.active{background:rgba(232,112,112,.15);}
.mode-select{display:flex;gap:10px;flex-wrap:wrap;justify-content:center;}
.mode-btn{padding:10px 16px;border:1px solid rgba(255,255,255,.15);border-radius:8px;background:rgba(255,255,255,.05);color:#fff;cursor:pointer;font-size:12px;font-weight:500;font-family:'DM Sans',sans-serif;transition:all .2s;text-align:center;}
.mode-btn:hover{background:rgba(232,112,112,.15);border-color:#e87070;}
.mode-btn.active{background:#8b1a1a;border-color:#8b1a1a;color:#fff;font-weight:600;}
.mode-btn .mode-icon{font-size:18px;display:block;margin-bottom:2px;}
.start-btn{padding:13px 38px;background:#8b1a1a;color:#fff;border:none;border-radius:8px;font-size:15px;font-weight:700;font-family:'DM Sans',sans-serif;cursor:pointer;transition:all .2s;}
.start-btn:hover{background:#6a0f0f;transform:translateY(-2px);box-shadow:0 6px 20px rgba(139,26,26,.35);}

#study-screen{display:none;position:relative;z-index:1;max-width:960px;margin:0 auto;padding:28px 24px 60px;}
#study-screen.active{display:block;}
.study-header{text-align:center;margin-bottom:32px;padding:34px 28px;background:var(--ink);border-radius:20px;position:relative;overflow:hidden;}
.study-header::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 80% 80% at 50% 50%,rgba(139,26,26,.12) 0%,transparent 70%);}
.study-header-icon{font-size:44px;display:block;margin-bottom:14px;position:relative;}
.study-header h1{font-family:'DM Serif Display',serif;font-size:clamp(20px,5vw,34px);color:#fff;position:relative;}
.study-header h1 span{color:#e87070;}
.study-header-sub{font-family:'Amiri',serif;font-size:19px;color:rgba(255,255,255,.6);margin-top:8px;direction:rtl;position:relative;}
.study-header-meta{margin-top:14px;display:flex;gap:16px;justify-content:center;flex-wrap:wrap;position:relative;}
.study-header-meta span{background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.12);padding:5px 14px;border-radius:20px;font-size:11px;color:rgba(255,255,255,.55);}
.study-toc{background:var(--paper);border:1px solid var(--border);border-radius:16px;padding:22px 26px;margin-bottom:26px;box-shadow:var(--shadow);}
.study-toc h2{font-family:'DM Serif Display',serif;font-size:19px;margin-bottom:14px;}
.toc-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(190px,1fr));gap:9px;}
.toc-item{display:flex;align-items:center;gap:10px;padding:10px 14px;border-radius:10px;border:1.5px solid var(--border);cursor:pointer;transition:all .18s;text-decoration:none;color:var(--ink);}
.toc-item:hover{border-color:var(--red);background:#fff5f5;}
.toc-item .toc-icon{font-size:18px;}.toc-item .toc-label{font-size:12px;font-weight:600;}.toc-item .toc-label-ar{font-family:'Amiri',serif;font-size:12px;color:var(--ink-muted);}
.study-section{background:var(--paper);border:1px solid var(--border);border-radius:16px;padding:24px 28px;margin-bottom:20px;box-shadow:var(--shadow);scroll-margin-top:24px;}
.study-section-header{display:flex;align-items:center;gap:12px;margin-bottom:16px;padding-bottom:13px;border-bottom:2px solid var(--border);}
.study-section-icon{font-size:26px;}
.study-section-title{font-family:'DM Serif Display',serif;font-size:20px;}
.study-section-title-ar{font-family:'Amiri',serif;font-size:16px;color:var(--ink-muted);}
.study-section-badge{margin-left:auto;padding:4px 12px;border-radius:20px;font-size:11px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;}
.def-box{padding:14px 18px;border-radius:12px;margin-bottom:14px;}
.def-box.blue{background:var(--blue-light);border-left:4px solid var(--blue);}
.def-box.teal{background:var(--teal-light);border-left:4px solid var(--teal);}
.def-box.gold{background:#fef9ee;border-left:4px solid var(--gold);}
.def-box.green{background:var(--green-light);border-left:4px solid var(--green);}
.def-box.red{background:var(--red-light);border-left:4px solid var(--red);}
.def-box.purple{background:var(--purple-light);border-left:4px solid var(--purple);}
.def-box.orange{background:var(--orange-light);border-left:4px solid var(--orange);}
.def-en{font-size:13.5px;font-weight:500;line-height:1.6;}
.def-ar{font-family:'Amiri',serif;font-size:15px;direction:rtl;text-align:right;color:var(--ink-soft);margin-top:7px;padding-top:7px;border-top:1px dashed rgba(0,0,0,.1);line-height:1.7;}
.study-grid{display:grid;grid-template-columns:1fr 1fr;gap:11px;margin-top:13px;}
@media(max-width:580px){.study-grid{grid-template-columns:1fr;}}
.s-card{padding:13px 16px;border-radius:12px;border:1.5px solid var(--border);background:var(--cream);}
.s-card-num{font-family:'DM Serif Display',serif;font-size:16px;color:var(--red);margin-bottom:5px;}
.s-card-en{font-size:13px;font-weight:600;}
.s-card-ar{font-family:'Amiri',serif;font-size:13px;color:var(--ink-muted);direction:rtl;text-align:right;margin-top:3px;}
.s-card-desc{font-size:11.5px;color:var(--ink-muted);margin-top:5px;line-height:1.5;}
.two-col{display:grid;grid-template-columns:1fr 1fr;gap:13px;margin-top:13px;}
@media(max-width:600px){.two-col{grid-template-columns:1fr;}}
.col-card{padding:14px 18px;border-radius:12px;border:1.5px solid var(--border);}
.col-card.a{background:rgba(192,57,43,.05);border-color:var(--red);}
.col-card.b{background:rgba(26,58,140,.05);border-color:var(--blue);}
.col-card.c{background:rgba(14,90,106,.05);border-color:var(--teal);}
.col-card.d{background:rgba(26,107,74,.05);border-color:var(--green);}
.col-card.e{background:rgba(124,58,237,.05);border-color:var(--purple);}
.col-card.f{background:rgba(201,168,76,.05);border-color:var(--gold);}
.col-card h4{font-size:13px;font-weight:700;margin-bottom:7px;}
.col-card p,.col-card li{font-size:12px;line-height:1.6;color:var(--ink-soft);}
.col-card p.ar{font-family:'Amiri',serif;font-size:13px;direction:rtl;text-align:right;color:var(--ink-muted);margin-top:5px;}
.angina-grid{display:grid;grid-template-columns:1fr 1fr;gap:11px;margin-top:13px;}
@media(max-width:600px){.angina-grid{grid-template-columns:1fr;}}
.angina-card{border-radius:13px;overflow:hidden;border:1.5px solid var(--border);}
.angina-head{padding:10px 15px;font-size:12.5px;font-weight:700;color:#fff;}
.angina-head.stable{background:var(--green);}
.angina-head.unstable{background:var(--red);}
.angina-head.variant{background:var(--orange);}
.angina-head.silent{background:var(--blue);}
.angina-head.intractable{background:var(--purple);}
.angina-body{padding:10px 15px;font-size:12px;line-height:1.6;background:var(--cream);}
.angina-body .ar{font-family:'Amiri',serif;font-size:12px;direction:rtl;text-align:right;color:var(--ink-muted);margin-top:5px;padding-top:5px;border-top:1px dashed var(--border);}
.acs-steps{display:flex;flex-wrap:wrap;gap:10px;margin-top:13px;}
.acs-step{flex:1;min-width:110px;border-radius:12px;padding:12px 10px;text-align:center;border:1.5px solid var(--border);background:var(--cream);}
.acs-step-num{font-family:'DM Serif Display',serif;font-size:20px;color:var(--red);margin-bottom:4px;}
.acs-step-en{font-size:12px;font-weight:700;}
.acs-step-detail{font-size:11px;color:var(--ink-muted);margin-top:3px;}
.acs-step-ar{font-family:'Amiri',serif;font-size:11px;color:var(--ink-muted);direction:rtl;margin-top:4px;}
.study-list{list-style:none;display:flex;flex-direction:column;gap:7px;margin-top:11px;}
.study-list li{display:flex;gap:10px;align-items:flex-start;padding:8px 12px;border-radius:8px;background:var(--cream);border:1px solid var(--border);font-size:13px;line-height:1.5;}
.study-list li .li-icon{font-size:15px;flex-shrink:0;margin-top:1px;}
.care-grid{display:grid;grid-template-columns:1fr 1fr;gap:13px;margin-top:13px;}
@media(max-width:580px){.care-grid{grid-template-columns:1fr;}}
.care-card{padding:14px 18px;border-radius:12px;border:1.5px solid var(--border);background:var(--cream);}
.care-card h4{font-size:12.5px;font-weight:700;margin-bottom:8px;color:var(--red);}
.care-list{list-style:none;display:flex;flex-direction:column;gap:4px;}
.care-list li{font-size:12px;line-height:1.5;padding-left:14px;position:relative;color:var(--ink-soft);}
.care-list li::before{content:'✓';position:absolute;left:0;color:var(--green);font-weight:700;}
.crit-box{background:var(--ink);color:#fff;border-radius:14px;padding:16px 20px;margin-top:13px;}
.crit-box h4{font-family:'DM Serif Display',serif;font-size:16px;color:var(--gold-light);margin-bottom:10px;}
.crit-box li{font-size:12.5px;line-height:1.7;padding-left:14px;position:relative;color:rgba(255,255,255,.82);margin-bottom:3px;list-style:none;}
.crit-box li::before{content:'▸';position:absolute;left:0;color:#e87070;}
.start-quiz-btn{display:block;width:100%;max-width:340px;margin:34px auto 0;padding:15px;background:var(--ink);color:#fff;border:none;border-radius:10px;font-size:15px;font-weight:700;font-family:'DM Sans',sans-serif;cursor:pointer;transition:all .2s;text-align:center;}
.start-quiz-btn:hover{background:#1e2830;transform:translateY(-2px);}
.idx-table{width:100%;border-collapse:collapse;margin-top:13px;font-size:13px;}
.idx-table th{background:var(--ink);color:#fff;padding:10px 13px;font-weight:600;text-align:left;}
.idx-table td{padding:9px 13px;border-bottom:1px solid var(--border);font-size:12.5px;}
.idx-table tr:nth-child(even){background:var(--cream);}
.idx-table .ar-cell{font-family:'Amiri',serif;direction:rtl;text-align:right;}

#app{display:none;position:relative;z-index:1;}
#app.active{display:block;}
.app-top{background:var(--ink);position:sticky;top:0;z-index:50;padding:12px 20px;display:flex;align-items:center;gap:14px;}
.top-back{background:rgba(255,255,255,.1);border:none;color:#fff;border-radius:8px;padding:7px 14px;font-size:12px;font-weight:600;font-family:'DM Sans',sans-serif;cursor:pointer;}
.top-progress{flex:1;height:6px;background:rgba(255,255,255,.15);border-radius:3px;overflow:hidden;}
#prog-fill{height:100%;background:#e87070;border-radius:3px;transition:width .3s;}
#top-counter{font-size:13px;color:rgba(255,255,255,.7);font-weight:600;min-width:50px;text-align:right;}
#timer-box{display:none;align-items:center;gap:6px;background:rgba(232,112,112,.2);border:1px solid rgba(232,112,112,.4);border-radius:8px;padding:5px 12px;}
#timer-box.warning{background:rgba(192,57,43,.25);border-color:var(--red);}
#timer-val{font-size:14px;font-weight:700;color:#e87070;font-family:'DM Serif Display',serif;}
#timer-box.warning #timer-val{color:#e74c3c;}
.quiz-wrap{max-width:760px;margin:0 auto;padding:28px 20px 80px;}
#exam-notice{background:#fef3c7;border:1px solid #f0c040;border-radius:10px;padding:10px 16px;margin-bottom:18px;font-size:12.5px;color:#7a4f00;}
#exam-notice.hidden{display:none;}
.nav-grid-wrap{background:var(--paper);border:1px solid var(--border);border-radius:12px;padding:14px 16px;margin-bottom:20px;}
.nav-grid-title{font-size:11px;font-weight:700;color:var(--ink-muted);letter-spacing:.05em;text-transform:uppercase;margin-bottom:10px;}
#nav-grid{display:flex;flex-wrap:wrap;gap:6px;}
.nav-dot{width:30px;height:30px;border-radius:6px;border:1.5px solid var(--border);background:var(--cream);font-size:11px;font-weight:600;cursor:pointer;transition:all .15s;color:var(--ink-soft);}
.nav-dot.current{background:#8b1a1a;color:#fff;border-color:#8b1a1a;}
.nav-dot.correct{background:#d4ede2;border-color:var(--green);color:var(--green);}
.nav-dot.wrong{background:var(--red-light);border-color:var(--red);color:var(--red);}
.nav-dot.answered{background:var(--blue-light);border-color:var(--blue);color:var(--blue);}
.question-card{background:var(--paper);border:1px solid var(--border);border-radius:16px;padding:24px;box-shadow:var(--shadow);}
.card-header{display:flex;gap:16px;margin-bottom:20px;}
.q-number{font-family:'DM Serif Display',serif;font-size:28px;color:var(--red);line-height:1;flex-shrink:0;}
.q-text-block{flex:1;}
.section-chip{display:inline-block;padding:3px 10px;border-radius:12px;font-size:10.5px;font-weight:700;letter-spacing:.04em;margin-right:5px;}
.section-chip.mcq{background:#fce8e6;color:var(--red);}
.section-chip.tf{background:var(--teal-light);color:var(--teal);}
.section-chip.anatomy-t{background:var(--purple-light);color:var(--purple);}
.section-chip.coronary-t{background:var(--red-light);color:var(--red);}
.section-chip.cad-t{background:var(--orange-light);color:var(--orange);}
.section-chip.angina-t{background:var(--gold-light);color:var(--orange);}
.section-chip.acs-t{background:var(--red-light);color:var(--red);}
.section-chip.prevention-t{background:var(--green-light);color:var(--green);}
.section-chip.nursing-t{background:var(--teal-light);color:var(--teal);}
.q-en{font-size:16px;font-weight:500;line-height:1.55;color:var(--ink);margin-bottom:6px;}
.q-ar{font-family:'Amiri',serif;font-size:16px;direction:rtl;text-align:right;color:var(--ink-soft);line-height:1.7;}
.options-grid{display:flex;flex-direction:column;gap:9px;margin-bottom:16px;}
.opt{display:flex;align-items:center;gap:12px;padding:12px 16px;border-radius:11px;border:1.5px solid var(--border);cursor:pointer;transition:all .18s;background:#fff;text-align:left;width:100%;}
.opt:hover:not(.locked){border-color:var(--red);background:#fff5f5;}
.opt.selected{border-color:var(--red);background:#fff5f5;}
.opt.is-correct{border-color:var(--green);background:var(--green-light);}
.opt.is-wrong{border-color:var(--red);background:var(--red-light);}
.opt.locked{cursor:default;}
.opt-radio{width:18px;height:18px;border-radius:50%;border:2px solid var(--border);flex-shrink:0;transition:all .18s;}
.opt.selected .opt-radio{background:var(--red);border-color:var(--red);}
.opt.is-correct .opt-radio{background:var(--green);border-color:var(--green);}
.opt.is-wrong .opt-radio{background:var(--red);border-color:var(--red);}
.opt-text{flex:1;}
.opt-en{font-size:13.5px;font-weight:500;color:var(--ink);}
.opt-ar{font-family:'Amiri',serif;font-size:13px;direction:rtl;text-align:right;color:var(--ink-muted);margin-top:2px;}
.result-badge{font-size:16px;flex-shrink:0;}
.feedback-bar{padding:10px 16px;border-radius:8px;font-size:13px;font-weight:600;margin-bottom:12px;}
.feedback-bar.correct{background:var(--green-light);color:var(--green);}
.feedback-bar.wrong{background:var(--red-light);color:var(--red);}
.explanation-box{background:#f8f8fc;border:1px solid var(--border);border-radius:10px;padding:14px 16px;margin-bottom:12px;display:none;}
.explanation-box.show{display:block;}
.exp-title{font-size:11px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:var(--ink-muted);margin-bottom:7px;}
.explanation-box>div:nth-child(2){font-size:13px;line-height:1.6;color:var(--ink-soft);}
.exp-ar{font-family:'Amiri',serif;font-size:14px;direction:rtl;text-align:right;color:var(--ink-muted);margin-top:7px;padding-top:7px;border-top:1px dashed var(--border);line-height:1.7;}
.nav-buttons{display:flex;gap:10px;flex-wrap:wrap;}
.nav-btn{padding:10px 22px;border-radius:8px;border:1.5px solid var(--border);background:var(--cream);font-size:13px;font-weight:600;font-family:'DM Sans',sans-serif;cursor:pointer;transition:all .18s;color:var(--ink);}
.nav-btn:hover{border-color:var(--red);background:#fff5f5;}
.nav-btn.primary{background:#8b1a1a;color:#fff;border-color:#8b1a1a;}
.nav-btn.primary:hover{background:#6a0f0f;}
.nav-btn.red{background:var(--red);color:#fff;border-color:var(--red);}
.nav-btn:disabled{opacity:.4;cursor:not-allowed;}

#results-screen{display:none;position:relative;z-index:1;max-width:760px;margin:0 auto;padding:30px 20px 60px;}
#results-screen.active{display:block;}
.results-card{background:var(--paper);border:1px solid var(--border);border-radius:20px;padding:32px;box-shadow:var(--shadow);text-align:center;margin-bottom:20px;}
.score-ring-wrap{width:130px;height:130px;margin:0 auto 20px;}
.score-ring-wrap svg{transform:rotate(-90deg);}
#score-ring-circle{transition:stroke-dashoffset 1s ease;}
#res-pct{font-family:'DM Serif Display',serif;font-size:32px;color:var(--ink);}
